# =================================
# MAX AI - Configuration centralisée (EXEMPLE)
# =================================
# Copiez ce fichier vers .env et remplacez les valeurs par vos vraies clés

# Configuration du serveur Backend
PORT=3000
NODE_ENV=development

# Configuration PostgreSQL
DB_HOST=localhost
DB_NAME=maxai
DB_USER=postgres
DB_PASSWORD=password
DB_PORT=5432
DB_DIALECT=postgres

# Configuration JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Configuration CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# =================================
# APIs EXTERNES
# =================================

# Mistral AI Configuration
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_KEY=your-mistral-key-here

# =================================
# FIREBASE (Frontend)
# =================================
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-ABCDEF123

# =================================
# SYSTÈME FEEDBACK WEBHOOK
# =================================

# GitHub Configuration (pour créer des issues automatiquement)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repository-name

# Airtable Configuration (pour tracker les feedbacks)
AIRTABLE_API_KEY=pat_your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=app_your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Feedback

# =================================
# MONITORING & PERFORMANCE
# =================================

# Log Level
LOG_LEVEL=info

# Performance Monitoring
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002